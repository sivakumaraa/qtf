# ==========================================
# QuarryForce Backend - .gitignore
# ==========================================
# This file prevents sensitive files from being uploaded to GitHub

# Environment variables (DATABASE PASSWORDS!)
.env
.env.local
.env.production

# Dependencies
node_modules/
package-lock.json
npm-debug.log

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed

# Large files (uploads)
uploads/
public/uploads/
dist/
build/

# Temporary files
tmp/
temp/
*.tmp

# Testing
coverage/
.nyc_output

# Misc
.env.test
config.local.json
secrets.json
private/

